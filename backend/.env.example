# OptiBook backend env template.
# Copy this file to backend/.env and replace the placeholders below.
# Never commit a populated .env — it is gitignored at the repo root.

# Server
PORT=5000

# MongoDB Atlas or local. Required.
MONGODB_URI=mongodb://localhost:27017/optibook

# JWT — replace JWT_SECRET with a long random string (32+ chars).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d

# CORS — frontend origin allowed to call the API.
FRONTEND_URL=http://localhost:5173

# Clinic-level gate required for optometrist + admin login.
# Patients do not need this. Replace before deploying.
STAFF_GATE_USER=optibook
STAFF_GATE_PASS=changeme
